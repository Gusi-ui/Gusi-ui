# Copia este archivo a .dev.vars y rellena tus valores reales.
# cp .dev.vars.example .dev.vars
#
# Obtén RESEND_API_KEY en https://resend.com/api-keys
# ADMIN_TOKEN: el mismo que usas en producción (wrangler secret put ADMIN_TOKEN)

RESEND_API_KEY=re_tu_api_key_aqui
ADMIN_TOKEN=tu_token_admin_aqui

# Opcionales (reseñas de Google)
# GOOGLE_API_KEY=
# GOOGLE_PLACE_ID=

# Stripe — pasarela de pagos (obtén las claves en https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta

# Price IDs de Stripe (Dashboard → Productos → Precios)
STRIPE_PRICE_DESARROLLO_WEB_ONETIME=price_xxx
STRIPE_PRICE_OPTIMIZACION_WEB_ONETIME=price_xxx
STRIPE_PRICE_BACKEND_APIS_ONETIME=price_xxx
STRIPE_PRICE_MANTENIMIENTO_MONTHLY=price_xxx
