---
import Icon from '@/components/ui/Icon.astro';

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <h3>alamia.es</h3>
        <p>
          Desarrollador Freelance especializado en soluciones digitales modernas. Transformo ideas en
          experiencias digitales excepcionales.
        </p>
        <div class="footer-contact">
          <div class="contact-item">
            <Icon name="envelope" />
            <span>info@alamia.es</span>
          </div>
          <div class="contact-item">
            <Icon name="whatsapp" />
            <span>+34 619 027 645</span>
          </div>
          <div class="contact-item">
            <Icon name="location" />
            <span>Mataró, Barcelona</span>
          </div>
        </div>
      </div>

      <div class="footer-services-technologies">
        <div class="footer-services">
          <h4>Servicios</h4>
          <ul>
            <li>Desarrollo Web</li>
            <li>Aplicaciones Móviles</li>
            <li>E-Commerce</li>
            <li>Mantenimiento</li>
          </ul>
        </div>

        <div class="footer-technologies">
          <h4>Tecnologías</h4>
          <div class="tech-tags">
            <span class="tech-tag"><Icon name="react" /> React</span>
            <span class="tech-tag"><Icon name="node-js" /> Node.js</span>
            <span class="tech-tag"><Icon name="react" /> React Native</span>
            <span class="tech-tag"><Icon name="bolt" /> Astro</span>
            <span class="tech-tag"><Icon name="database" /> MongoDB</span>
            <span class="tech-tag"><Icon name="database" /> PostgreSQL</span>
          </div>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-bottom-content">
        <p>&copy; {currentYear} Jose Martínez (Gusi). Todos los derechos reservados.</p>
        <div class="footer-bottom-links">
          <div class="nav-links">
            <a href="#inicio">Inicio</a>
            <a href="#servicios">Servicios</a>
            <a href="#proyectos">Proyectos</a>
            <a href="#contacto">Contacto</a>
          </div>
          <div class="legal-links">
            <a href="/politica-privacidad/">Política de Privacidad</a>
            <a href="/terminos-servicio/">Términos de Servicio</a>
            <a href="/politica-cookies/">Cookies</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
