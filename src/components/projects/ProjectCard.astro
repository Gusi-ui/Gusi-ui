---
import Icon from '@/components/ui/Icon.astro';
import type { ProjectCaseStudy } from '@/data/project-case-studies';
import { getProjectDemoLabel, isExternalDemo } from '@/lib/project-demo';

interface Props {
  project: ProjectCaseStudy;
  whatsappUrl: string;
}

const { project, whatsappUrl } = Astro.props;
const whatsappHref = `${whatsappUrl}?text=${encodeURIComponent(project.whatsappMessage)}`;
const externalDemo = isExternalDemo(project.demoUrl);
const demoLabel = getProjectDemoLabel(project.demoUrl);
---

<article class="project-card" data-project-type={project.type} data-project-id={project.id}>
  <div class="project-image">
    <picture>
      {project.image.avif && <source srcset={`/${project.image.avif}`} type="image/avif" />}
      {project.image.webp && <source srcset={`/${project.image.webp}`} type="image/webp" />}
      <img src={`/${project.image.jpg}`} alt={project.image.alt} loading="lazy" />
    </picture>
    <div class="project-overlay">
      <div class="project-actions">
        <a
          href={project.demoUrl}
          class="project-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="eye" />
          <span>{externalDemo ? 'Visitar' : 'Ver demo'}</span>
        </a>
        <a href={`/proyectos/${project.id}/`} class="project-btn project-btn-case">
          <Icon name="compass" />
          <span>Ver caso</span>
        </a>
      </div>
    </div>
  </div>
  <div class="project-content">
    <div class="project-card-meta">
      <div class="project-badge">{project.badge}</div>
      <span class="project-demo-label">{demoLabel}</span>
    </div>
    <h3 class="project-title">
      <a href={`/proyectos/${project.id}/`}>{project.title}</a>
    </h3>
    <p class="project-description">{project.hook}</p>
    <p class="project-metric">
      <Icon name="bolt" />
      <span>{project.featuredMetric}</span>
    </p>
    <div class="project-tech">
      {project.tech.map((tech) => (
        <span class="tech-tag">{tech}</span>
      ))}
    </div>
    <div class="project-card-footer">
      <span class="project-price">desde €{project.servicePrice}</span>
      <a href={whatsappHref} class="project-whatsapp-link" target="_blank" rel="noopener">
        <Icon name="whatsapp" />
        <span>Quiero algo similar</span>
      </a>
    </div>
  </div>
</article>
