---
import Icon from '@/components/ui/Icon.astro';
---

<aside class="blog-sidebar-card blog-sidebar-card--author">
  <img
    src="/images/optimizadas/tu-foto-perfil.webp"
    alt="Jose Martínez — desarrollador freelance"
    class="blog-author__avatar"
    width="72"
    height="72"
    loading="lazy"
    decoding="async"
  />
  <h2 class="blog-sidebar-card__title">Jose Martínez</h2>
  <p class="blog-sidebar-card__text">
    Desarrollador freelance en Mataró (Barcelona). Especializado en webs rápidas, APIs y
    mantenimiento para autónomos y PYMEs.
  </p>
  <a href="/#contacto" class="blog-sidebar-card__link">
    <Icon name="envelope" />
    <span>Solicitar presupuesto</span>
  </a>
</aside>
