---
import ProjectsShowcase from '@/islands/ProjectsShowcase';
import ProjectFilter from '@/islands/ProjectFilter';
import ProjectCard from '@/components/projects/ProjectCard.astro';
import { projects } from '@/data/projects';
import { toDisplayProjects } from '@/lib/projects-display';
import { WHATSAPP_URL } from '@/lib/constants';

interface Props {
  mode?: 'rotating' | 'all';
}

const { mode = 'rotating' } = Astro.props;
const displayProjects = toDisplayProjects(projects);
---

<section id="proyectos" class="projects">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Mis Proyectos</h2>
      <p class="section-subtitle">
        {
          mode === 'rotating'
            ? 'Casos de estudio con demos en vivo. Cada visita muestra una selección distinta para que descubras más soluciones.'
            : 'Explora todos los casos de estudio con demos funcionales. Cada proyecto resuelve un problema real de negocio.'
        }
      </p>
      <div class="section-divider"></div>
    </div>

    {
      mode === 'rotating' ? (
        <ProjectsShowcase
          client:visible
          projects={displayProjects}
          whatsappUrl={WHATSAPP_URL}
          visibleCount={3}
          showViewAll={true}
        />
      ) : (
        <>
          <ProjectFilter client:visible />
          <div class="projects-grid" id="projects-grid">
            {projects.map((project) => (
              <ProjectCard project={project} whatsappUrl={WHATSAPP_URL} />
            ))}
          </div>
        </>
      )
    }
  </div>
</section>
