---
import { projectServices, maintenanceService } from '@/data/services';
import ServiceCard from '@/islands/ServiceCard.tsx';
import MaintenanceCard from '@/islands/MaintenanceCard.tsx';
import { isStripeConfigured } from '@/lib/payments/stripe-client';

const stripeEnabled = isStripeConfigured();
---

<section id="servicios" class="services" itemscope itemtype="https://schema.org/Service">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Mis Servicios</h2>
      <p class="section-subtitle">
        Elige el servicio que necesitas. Un clic y pagas de forma segura.
      </p>
      <div class="section-divider"></div>
    </div>

    <div class="services-grid services-grid--projects">
      {
        projectServices.map((service) => (
          <div class="services-grid__cell">
            <ServiceCard client:visible service={service} stripeEnabled={stripeEnabled} />
          </div>
        ))
      }
    </div>

    <MaintenanceCard client:visible service={maintenanceService} stripeEnabled={stripeEnabled} />
  </div>
</section>
