---
import Icon from '@/components/ui/Icon.astro';
import { WHATSAPP_URL } from '@/lib/constants';
---

<section id="inicio" class="hero" itemscope itemtype="https://schema.org/Person">
  <div class="hero-background">
    <div class="hero-pattern"></div>
  </div>
  <div class="hero-container">
    <div class="hero-content">
      <div class="hero-text">
        <div class="hero-badge">
          <Icon name="code" />
          <span>Desarrollador Freelance</span>
        </div>
        <h1 class="hero-title">
          <span class="hero-name" itemprop="name">Jose Martínez</span>
          <span class="hero-alias"><span class="highlight" itemprop="alternateName">Gusi</span></span>
        </h1>
        <p class="hero-description">
          Transformo ideas en experiencias digitales excepcionales. Especializado en desarrollo web
          moderno, aplicaciones móviles y soluciones personalizadas que impulsan el crecimiento de tu
          negocio.
        </p>
        <div class="hero-stats">
          <div class="stat-item">
            <div class="stat-number">50+</div>
            <div class="stat-label">Proyectos</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">3+</div>
            <div class="stat-label">Años</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Satisfacción</div>
          </div>
        </div>
        <div class="hero-buttons">
          <a href="#proyectos" class="btn btn-primary" role="button" aria-label="Ver mis proyectos realizados">
            <Icon name="rocket" />
            <span>Ver Proyectos</span>
          </a>
          <a
            href={WHATSAPP_URL}
            class="btn btn-whatsapp"
            target="_blank"
            rel="noopener"
            role="button"
            aria-label="Contratar servicios por WhatsApp"
          >
            <Icon name="whatsapp" />
            <span>Contratar Ahora</span>
          </a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-image-container">
          <div class="hero-bg-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
          </div>
          <div class="hero-image-wrapper">
            <div class="hero-image">
              <picture>
                <source
                  srcset="/images/optimizadas/tu-foto-perfil.avif"
                  type="image/avif"
                />
                <source
                  srcset="/images/optimizadas/tu-foto-perfil.webp"
                  type="image/webp"
                />
                <img
                  src="/tu-foto-perfil-optimizada.jpg"
                  alt="Jose Martínez - Desarrollador Freelance"
                  class="profile-image critical-image"
                  itemprop="image"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  width="400"
                  height="500"
                />
              </picture>
              <div class="image-overlay"></div>
              <div class="image-frame"></div>
            </div>
            <div class="floating-elements">
              <div class="floating-icon icon-1">
                <Icon name="react" />
                <div class="icon-glow"></div>
              </div>
              <div class="floating-icon icon-2">
                <Icon name="node-js" />
                <div class="icon-glow"></div>
              </div>
              <div class="floating-icon icon-3">
                <Icon name="mobile" />
                <div class="icon-glow"></div>
              </div>
              <div class="floating-icon icon-4">
                <Icon name="database" />
                <div class="icon-glow"></div>
              </div>
            </div>
            <div class="connection-lines">
              <div class="line line-1"></div>
              <div class="line line-2"></div>
              <div class="line line-3"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
