---
import SimplePageLayout from '@/layouts/SimplePageLayout.astro';
import Icon from '@/components/ui/Icon.astro';
import { projectServices, maintenanceService } from '@/data/services';
import { WHATSAPP_URL } from '@/lib/constants';

const productSlug = Astro.url.searchParams.get('product');
const allServices = [...projectServices, maintenanceService];
const product = allServices.find((s) => s.slug === productSlug);
const year = new Date().getFullYear();
---

<SimplePageLayout title="Pago cancelado | alamia.es" noindex>
  <div class="container checkout-page">
    <div class="checkout-status checkout-status-cancel">
      <Icon name="times-circle" />
      <h2>Pago cancelado</h2>
      <p>No se ha realizado ningún cargo. Puedes volver a intentarlo cuando quieras.</p>
      {
        product && (
          <p class="checkout-product">
            Servicio seleccionado: <strong>{product.title}</strong>
          </p>
        )
      }
      <div class="checkout-actions">
        <a href="/#servicios" class="btn btn-primary">
          <Icon name="arrow-left" /> Volver a servicios
        </a>
        <a href={WHATSAPP_URL} class="btn btn-whatsapp" target="_blank" rel="noopener noreferrer">
          <Icon name="whatsapp" /> Consultar por WhatsApp
        </a>
      </div>
      <p class="checkout-footer">&copy; {year} Jose Martínez (Gusi) — alamia.es</p>
    </div>
  </div>
</SimplePageLayout>
