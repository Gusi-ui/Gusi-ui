---
import SimplePageLayout from '@/layouts/SimplePageLayout.astro';
import Icon from '@/components/ui/Icon.astro';
import { graciasDefault } from '@/data/gracias';
import { WHATSAPP_URL } from '@/lib/constants';

const page = graciasDefault;
const year = new Date().getFullYear();
---

<SimplePageLayout title={page.title} noindex>
  <div class="container" style="padding: 6rem 1rem 4rem;">
    <div
      class="success-container"
      style="max-width: 600px; margin: 0 auto; background: white; border-radius: 1.5rem; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);"
    >
      <div style="background: linear-gradient(135deg, #10b981, #059669); color: white; padding: 3rem 2rem; text-align: center;">
        <span style="font-size: 3rem; margin-bottom: 1rem; display: block;">
          <Icon name={page.icon} />
        </span>
        <h1 style="font-size: 1.75rem; margin-bottom: 0.5rem;">{page.heading}</h1>
        <p style="opacity: 0.9;">{page.subtitle}</p>
      </div>
      <div style="padding: 2rem;">
        <a href="/" class="btn btn-primary" style="text-decoration: none; margin-right: 1rem;">
          <Icon name="home" /> Volver al inicio
        </a>
        <a href={WHATSAPP_URL} class="btn btn-whatsapp" target="_blank" rel="noopener" style="text-decoration: none;">
          <Icon name="whatsapp" /> WhatsApp
        </a>
        <p style="margin-top: 2rem; color: #64748b; font-size: 0.875rem; text-align: center;">
          &copy; {year} Jose Martínez (Gusi) — alamia.es
        </p>
      </div>
    </div>
  </div>
</SimplePageLayout>
