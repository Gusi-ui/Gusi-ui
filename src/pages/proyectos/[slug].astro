---
import ContentLayout from '@/layouts/ContentLayout.astro';
import ProjectCaseStudy from '@/components/pages/ProjectCaseStudy.astro';
import { projectCaseStudies, getRelatedProjects } from '@/data/project-case-studies';
import { SITE_URL } from '@/lib/constants';

export function getStaticPaths() {
  return projectCaseStudies.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const relatedProjects = getRelatedProjects(project.id).map((item) => ({
  id: item.id,
  title: item.title,
  hook: item.hook,
}));
const canonical = `${SITE_URL}/proyectos/${project.id}/`;
const ogImage = `/${project.image.jpg}`;
---

<ContentLayout
  title={`${project.metaTitle} | alamia.es`}
  description={project.metaDescription}
  canonical={canonical}
  ogImage={ogImage}
>
  <ProjectCaseStudy project={project} relatedProjects={relatedProjects} />
</ContentLayout>
