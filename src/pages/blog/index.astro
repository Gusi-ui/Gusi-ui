---
import ContentLayout from '@/layouts/ContentLayout.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import Icon from '@/components/ui/Icon.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = 'Blog de desarrollo web | alamia.es';
const description =
  'Guías sobre desarrollo web, APIs, mantenimiento y precios para autónomos y PYMEs. Consejos técnicos explicados sin jerga.';
---

<ContentLayout title={title} description={description}>
  <div class="blog-index">
    <div class="container">
      <header class="blog-index__header">
        <nav class="service-landing__breadcrumb" aria-label="Migas de pan">
          <a href="/">Inicio</a>
          <span aria-hidden="true">/</span>
          <span>Blog</span>
        </nav>

        <h1 class="service-landing__title">Blog de desarrollo web</h1>
        <p class="service-landing__subtitle">
          Guías prácticas sobre desarrollo web, backend, rendimiento y mantenimiento para autónomos
          y pequeñas empresas. Sin jerga innecesaria.
        </p>
      </header>

      <div class="blog-index__grid">
        {posts.map((post) => <BlogCard post={post} />)}
      </div>

      <div class="blog-index__footer-cta">
        <p>¿Prefieres hablar directamente sobre tu proyecto?</p>
        <div class="service-landing__cta-row">
          <a href="/servicios/" class="btn btn-primary">
            <Icon name="laptop-code" />
            <span>Ver servicios y precios</span>
          </a>
          <a href="/#contacto" class="btn btn-secondary">
            <Icon name="envelope" />
            <span>Contactar</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</ContentLayout>
