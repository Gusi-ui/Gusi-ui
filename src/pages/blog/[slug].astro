---
import ContentLayout from '@/layouts/ContentLayout.astro';
import Icon from '@/components/ui/Icon.astro';
import { getCollection, render } from 'astro:content';
import { getServiceLandingPath } from '@/data/service-landings';
import type { ServiceSlug } from '@/data/service-landings';
import { SITE_URL } from '@/lib/constants';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const canonical = new URL(Astro.url.pathname, SITE_URL).href;

const siloLabels: Record<ServiceSlug, string> = {
  'desarrollo-web': 'Desarrollo Web',
  'optimizacion-web': 'Optimización Web',
  'backend-apis': 'Backend & APIs',
  mantenimiento: 'Mantenimiento Web',
};

const servicePath = getServiceLandingPath(post.data.serviceSilo);
const serviceLabel = siloLabels[post.data.serviceSilo];

const ctaCopy: Record<ServiceSlug, { title: string; text: string; button: string }> = {
  'desarrollo-web': {
    title: '¿Necesitas una web para tu negocio?',
    text: 'Desarrollo web profesional desde 250€ con entrega en 7-10 días.',
    button: 'Ver servicio de desarrollo web',
  },
  'optimizacion-web': {
    title: '¿Tu web carga lenta?',
    text: 'Optimización de Core Web Vitals desde 190€ con informe antes/después.',
    button: 'Ver servicio de optimización',
  },
  'backend-apis': {
    title: '¿Tu proyecto necesita un backend?',
    text: 'APIs REST documentadas y panel admin desde 400€.',
    button: 'Ver servicio de backend y APIs',
  },
  mantenimiento: {
    title: '¿Quieres olvidarte del mantenimiento técnico?',
    text: 'Plan mensual desde 10€ con backups, seguridad y soporte.',
    button: 'Ver plan de mantenimiento',
  },
};

const cta = ctaCopy[post.data.serviceSilo];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: 'Jose Martínez',
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    name: 'alamia.es',
    url: SITE_URL,
  },
  mainEntityOfPage: canonical,
};
---

<ContentLayout title={`${post.data.title} | alamia.es`} description={post.data.description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />

  <article class="container">
    <header class="blog-post__header">
      <nav class="service-landing__breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/blog/">Blog</a>
        <span aria-hidden="true">/</span>
        <span>{serviceLabel}</span>
      </nav>

      <h1 class="blog-post__title">{post.data.title}</h1>
      <p class="blog-post__meta">
        {post.data.pubDate.toLocaleDateString('es-ES', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
        {' · '}
        <a href={servicePath}>{serviceLabel}</a>
      </p>
    </header>

    <div class="blog-post__content">
      <Content />

      <aside class="blog-post__cta">
        <h3>{cta.title}</h3>
        <p>{cta.text}</p>
        <a href={servicePath} class="btn btn-primary" style="margin-top: 1rem; text-decoration: none;">
          <Icon name="chevron-right" />
          <span>{cta.button}</span>
        </a>
      </aside>
    </div>
  </article>
</ContentLayout>
