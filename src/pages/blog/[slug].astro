---
import ContentLayout from '@/layouts/ContentLayout.astro';
import BlogPostHero from '@/components/blog/BlogPostHero.astro';
import BlogServiceCta from '@/components/blog/BlogServiceCta.astro';
import BlogAuthorCard from '@/components/blog/BlogAuthorCard.astro';
import BlogRelatedPosts from '@/components/blog/BlogRelatedPosts.astro';
import Icon from '@/components/ui/Icon.astro';
import { getCollection, render } from 'astro:content';
import {
  BLOG_CTA_BY_SILO,
  getBlogHeroImage,
  getReadingTime,
  SILO_LABELS,
} from '@/lib/blog';
import { SITE_URL } from '@/lib/constants';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const canonical = new URL(Astro.url.pathname, SITE_URL).href;
const heroImage = getBlogHeroImage(post.data.serviceSilo, post.data.heroImage);
const heroImageUrl = heroImage.startsWith('http') ? heroImage : `${SITE_URL}${heroImage}`;
const readingTime = getReadingTime(post.body ?? '');
const cta = BLOG_CTA_BY_SILO[post.data.serviceSilo];

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedFromFrontmatter = (post.data.relatedSlugs ?? [])
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter(Boolean);

const relatedFromSilo =
  relatedFromFrontmatter.length > 0
    ? relatedFromFrontmatter
    : allPosts.filter((p) => p.id !== post.id && p.data.serviceSilo === post.data.serviceSilo);

const relatedPosts = relatedFromSilo.slice(0, 3).map((p) => ({
  slug: p!.id,
  title: p!.data.title,
  description: p!.data.description,
}));

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  image: heroImageUrl,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: 'Jose Martínez',
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    name: 'alamia.es',
    url: SITE_URL,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE_URL}/freelancer-icon-optimizado.png`,
    },
  },
  mainEntityOfPage: canonical,
};
---

<ContentLayout
  title={`${post.data.title} | alamia.es`}
  description={post.data.description}
  ogImage={heroImage}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />

  <article class="blog-article">
    <BlogPostHero
      slug={post.id}
      title={post.data.title}
      description={post.data.description}
      pubDate={post.data.pubDate}
      serviceSilo={post.data.serviceSilo}
      heroImage={post.data.heroImage}
      imageAlt={post.data.imageAlt}
      readingTime={readingTime}
    />

    <div class="container blog-article__layout">
      <div class="blog-post__content blog-prose">
        <Content />

        <aside class="blog-post__inline-cta">
          <div class="blog-post__inline-cta-inner">
            <span class="blog-post__inline-cta-label">¿Te ha sido útil?</span>
            <h2>{cta.title}</h2>
            <p>{cta.text}</p>
            <div class="blog-post__inline-cta-actions">
              <a href={cta.href} class="btn btn-primary">
                <Icon name="chevron-right" />
                <span>{cta.button}</span>
              </a>
              <a href="/blog/" class="btn btn-secondary">
                <Icon name="compass" />
                <span>Más artículos</span>
              </a>
            </div>
          </div>
        </aside>
      </div>

      <aside class="blog-article__sidebar" aria-label="Información relacionada">
        <BlogServiceCta
          title={cta.title}
          text={cta.text}
          button={cta.button}
          href={cta.href}
        />
        <BlogAuthorCard />
        <BlogRelatedPosts posts={relatedPosts} />
      </aside>
    </div>
  </article>
</ContentLayout>
