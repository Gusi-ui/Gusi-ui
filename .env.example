# Copia a .env en la raíz del proyecto para desarrollo local con Astro
# cp .env.example .env

# Stripe — clave publicable (segura en el Frontend)
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica

# Cloudflare API token (solo para MCP / operaciones de zona desde Cursor)
# Crear en: https://dash.cloudflare.com/profile/api-tokens
#
# IMPORTANTE para MCP (https://mcp.cloudflare.com/mcp):
# El token debe poder leer usuario Y cuenta, no solo la zona.
# Permisos mínimos:
#   User → User Details → Read
#   Account → Account Settings → Read  (cuenta Gusi)
#   Zone → Cache Purge → Edit
#   Zone → Zone Settings → Edit
#   Zone → Zone → Read
# Recursos: zona alamia.es
#
# Sin User/Account Read verás: "no user or account information" (401 en MCP)
CLOUDFLARE_API_TOKEN=

# Los Price IDs se configuran en el Cloudflare Worker (secrets), no aquí.
# Ver worker/.dev.vars.example
